# Production config. Loaded when NODE_ENV=production.
# Committed alongside backend/.env (same convention as sandbox-manager).
# Secrets are __PLACEHOLDER__ tokens — the server fills them in at deploy
# time via sed / vault / whatever the ops convention is.

NODE_ENV=production
HEADLESS=true

# Ports (must match nginx upstreams + ecosystem.config.cjs slot math).
# Slot A defaults; ecosystem.config.cjs re-derives all three for slot B
# (+2/+12/+22/+32 via DEPLOY_PORT). These values only kick in if PM2 is
# not running through ecosystem.config.cjs (e.g. manual `tsx server.ts`).
BROWSER_MANAGER_PORT=8600         # REST API
BROWSER_MANAGER_ADMIN_PORT=8610   # Admin REST (internal only, bound to 127.0.0.1)
BROWSER_MANAGER_CDP_PORT=8620     # CDP proxy (internal only)
BROWSER_MANAGER_NOISE_PORT=8630   # Noise RPC (internal only)

# Shared bearer between backend (BrowserManagerClient) and BM admin routes.
BROWSER_MANAGER_ADMIN_KEY=__BROWSER_MANAGER_ADMIN_KEY__

# Noise (required to enable Noise RPC). 32 bytes hex.
NOISE_LOCAL_PRIVATE_KEY=__NOISE_LOCAL_PRIVATE_KEY__

# Where hibernated session JSON is stored. Survives restarts; do not put on tmpfs.
HIBERNATE_DIR=/var/app/browser-manager/hibernate-data
