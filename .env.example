NODE_ENV=development
HEADLESS=true

# Ports
BROWSER_MANAGER_PORT=8086        # REST API
BROWSER_MANAGER_ADMIN_PORT=8085  # CDP proxy (internal only)
BROWSER_MANAGER_NOISE_PORT=8087  # Noise RPC (internal only)

# Auth (optional; if unset, auth is disabled)
BROWSER_MANAGER_API_KEY=

# Noise (required to enable Noise RPC)
NOISE_LOCAL_PRIVATE_KEY=
NOISE_REMOTE_PUBLIC_KEY=

# Hibernate
HIBERNATE_DIR=./hibernate-data   # where hibernated session JSON is stored
