NODE_ENV=development
HEADLESS=true

# Ports
BROWSER_MANAGER_PORT=8600        # REST API
BROWSER_MANAGER_ADMIN_PORT=8610  # Admin REST (internal only, bound to 127.0.0.1)
BROWSER_MANAGER_CDP_PORT=8620    # CDP proxy (internal only)
BROWSER_MANAGER_NOISE_PORT=8630  # Noise RPC (internal only)

# Admin key — server-to-server only. CLI/agent users authenticate with their
# login token from api.todofor.ai; this key is for backend ops that need to
# act on behalf of a user (must pass X-Act-As or act_as).
BROWSER_MANAGER_ADMIN_KEY=

# Noise (required to enable Noise RPC)
NOISE_LOCAL_PRIVATE_KEY=

# Hibernate
HIBERNATE_DIR=./hibernate-data   # where hibernated session JSON is stored
