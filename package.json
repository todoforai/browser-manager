{
  "name": "browser-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "CDP browser session manager — spawns Chromium instances and proxies raw CDP WebSocket per session",
  "main": "server.ts",
  "scripts": {
    "dev": "bun --watch server.ts",
    "start": "bun server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "web:dev": "bun run web/dev-server.js",
    "install-browsers": "node node_modules/cloakbrowser/dist/cli.js install"
  },
  "dependencies": {
    "@shared/web": "file:./vendor/shared-web",
    "@todoforai/noise": "file:../noise-ts",
    "cloakbrowser": "^0.4.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mmdb-lib": "^3.0.2",
    "playwright-core": "^1.58.0",
    "socks-proxy-agent": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
